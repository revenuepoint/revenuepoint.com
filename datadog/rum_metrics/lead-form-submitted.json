{
  "id": "rum.action.lead_form_submitted.count",
  "type": "rum_metrics",
  "attributes": {
    "compute": { "aggregation_type": "count" },
    "event_type": "action",
    "filter": { "query": "@action.name:lead_form_submitted" },
    "group_by": [
      { "path": "service", "tag_name": "service" },
      { "path": "env", "tag_name": "env" },
      { "path": "version", "tag_name": "version" }
    ]
  }
}
